rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // USUÁRIOS
    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // POSTAGENS
    match /postagens/{postagemId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.jogador_id == request.auth.uid;
      allow update: if request.auth != null 
                    && resource.data.jogador_id == request.auth.uid 
                    && request.resource.data.jogador_id == request.auth.uid;
      allow delete: if request.auth != null && resource.data.jogador_id == request.auth.uid;
    }

    // AVALIAÇÕES
    match /avaliacoes/{avaliacaoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.autor_id == request.auth.uid;
      allow update: if request.auth != null 
                    && resource.data.autor_id == request.auth.uid
                    && request.resource.data.autor_id == request.auth.uid;
      allow delete: if request.auth != null 
                    && (resource.data.autor_id == request.auth.uid || resource.data.jogador_id == request.auth.uid);
    }

    // FAVORITOS
    match /favoritos/{favoritoId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.interessado_id == request.auth.uid;
      allow delete: if request.auth != null 
                    && (resource.data.interessado_id == request.auth.uid || resource.data.jogador_id == request.auth.uid);
    }

    // NOTIFICAÇÕES
    match /notificacoes/{notificacaoId} {
  	allow read, update: if request.auth != null 
                      	&& (resource.data.usuario_id == request.auth.uid
                      	|| resource.data.remetente_id == request.auth.uid);
  	allow create: if request.auth != null && request.resource.data.remetente_id == request.auth.uid;
  	allow delete: if request.auth != null 
                	&& (resource.data.usuario_id == request.auth.uid 
                	|| resource.data.remetente_id == request.auth.uid);
		}

    // CHATS E MENSAGENS
    match /chats/{chatId} {
      allow read, update, delete: if request.auth != null && request.auth.uid in resource.data.participantes;
      allow create: if request.auth != null && request.auth.uid in request.resource.data.participantes;

      match /mensagens/{mensagemId} {
        allow read: if request.auth != null 
                    && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes;
        allow create: if request.auth != null 
                      && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participantes
                      && request.resource.data.remetente_id == request.auth.uid;
      }
    }
    
    // DICATREINO E TREINO
    match /dica_treino/{dicaTreinoId} {
    	allow read: if request.auth != null;
      
      match /exercicio/{exercicioId} {
      	allow read: if request.auth != null;
      }
    }

  }
}